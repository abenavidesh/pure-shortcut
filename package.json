{
    "name": "pure-shortcut",
    "version": "2.0.1",
    "type": "module",
    "main": "dist/index.umd.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "license":"MIT",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require":"./dist/index.umd.cjs"
        }
    },
    "peerDependencies": {
        "react": "^18 || ^19",
        "react-dom": "^18 || ^19"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "@types/react": "^19.2.14",
        "tailwindcss": "^4.2.1"
    },
    "scripts": {
        "build": "vite build",
        "build:core": "vite build --config vite.core.config.ts",
        "build:all": "npm run build && npm run build:core"
    },
    "keywords": [
        "shortcut",
        "hotkey",
        "react",
        "keyboard",
        "hook",
        "shortcuts",
        "keyboard-shortcut",
        "custom-keyboard-shortcut",
        "react-component",
        "keybinding",
        "keyboard-event",
        "tailwind",
        "typescript",
        "shortcut-provider"
    ]
}
